# ─────────────────────────────────────────────────────────────
# SRV School Management App — Environment Variables Template
# Copy this file to .env (never commit .env to version control)
# ─────────────────────────────────────────────────────────────

# ── BACKEND (server/.env) ────────────────────────────────────

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret key — use a long, random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_32_chars

# Server port (optional, defaults to 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Allowed CORS origin for your frontend (add your production URL here)
# In development this defaults to http://localhost:3000
CORS_ORIGIN=https://your-frontend-app.vercel.app

# ── FRONTEND (.env in project root) ─────────────────────────

# Backend API base URL — no trailing slash (required)
VITE_API_URL=https://srv-backend-3b9s.onrender.com

# Gemini API key (if using AI features)
GEMINI_API_KEY=your_gemini_api_key_here
